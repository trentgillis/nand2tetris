// and the book "The Elements of Computing Systems"
// by Nisan and Schocken, MIT Press.

/**
 * A library of functions for displaying graphics on the screen.
 * The Hack physical screen consists of 512 rows (indexed 0..511, top to bottom)
 * of 256 pixels each (indexed 0..255, left to right). The top left pixel on
 * the screen is indexed (0,0).
 */
class Screen {
    static boolean color;
    static int screen;
    static Array powersOfTwo;

    /** Initializes the Screen. */
    function void init() {
        var int curr, i;
        let color = true;
        let screen = 16384;

        // This would be done using the implementation in Math, but as I'm testing
        // this with the built in methods I've duplicated it here for the bit()
        // function. The actual OS as I've implemented it wouldn't need this
        // duplication.
        let powersOfTwo = Array.new(16);
        let curr = 1;
        let i = 0;
        while (i < 16) {
            let powersOfTwo[i] = curr;
            let curr = curr + curr;
            let i = i + 1;
        }

        return;
    }

    /** Erases the entire screen. */
    function void clearScreen() {
        var int i;

        let i = 0;
        while (i < 8192) {
            let screen[i] = false;
            let i = i + 1;
        }

        return;
    }

    /** Sets the current color, to be used for all subsequent drawXXX commands.
     *  Black is represented by true, white by false. */
    function void setColor(boolean b) {
        let color = b;
        return;
    }

    /** Draws the (x,y) pixel, using the current color. */
    function void drawPixel(int x, int y) {
        var int i, pixel, addr;
        var boolean b;

        let addr = screen + (y * 32) + (x / 16);
        let pixel = x - (x / 16 * 16);

        if (color) {
            do Memory.poke(addr, Memory.peek(addr) | powersOfTwo[pixel]);
        } else {
            do Memory.poke(addr, Memory.peek(addr) & ~powersOfTwo[pixel]);
        }

        return;
    }

    /** Draws a line from pixel (x1,y1) to pixel (x2,y2), using the current color. */
    function void drawLine(int x1, int y1, int x2, int y2) {
        var int x, y, dx, dy, a, ad, b, bd, diff;

        let a = 0;
        let b = 0;
        let diff = 0;
        let x = x1;
        let y = y1;
        let dx = Math.abs(x2 - x1);
        let dy = Math.abs(y2 - y1);

        if (x1 < x2) {
            let ad = 1;
        } else {
            let ad = -1;
        }

        if (y1 < y2) {
            let bd = 1;
        } else {
            let bd = -1;
        }

        if (dy = 0) {
            while (~(Math.abs(a) > dx)) {
                do Screen.drawPixel(x + a, y);
                let a = a + ad;
            }
            return;
        }

        if (dx = 0) {
            while (~(Math.abs(b) > dy)) {
                do Screen.drawPixel(x, y + b);
                let b = b + bd;
            }
            return;
        }

        while (~(Math.abs(a) > dx) & ~(Math.abs(b) > dy)) {
            do Screen.drawPixel(x + a, y + b);
            if (diff < 0) {
                let a = a + ad;
                let diff = diff + dy;
            } else {
                let b = b + bd;
                let diff = diff - dx;
            }
        }

        return;
    }

    /** Draws a filled rectangle whose top left corner is (x1, y1)
     *  and bottom right corner is (x2,y2), using the current color. */
    function void drawRectangle(int x1, int y1, int x2, int y2) {
        while (~(y1 > y2)) {
            do Screen.drawLine(x1, y1, x2, y1);
            let y1 = y1 + 1;
        }
        return;
    }

    /** Draws a filled circle of radius r<=181 around (x,y), using the current color. */
    function void drawCircle(int x, int y, int r) {
        var int dx, dy;

        let dy = -r;
        while (~(dy > r)) {
            let dx = Math.sqrt((r * r) - (dy * dy));
            do Screen.drawLine(x - dx, y + dy, x + dx, y + dy);
            let dy = dy + 1;
        }

        return;
    }
}
